      }
    },
    "Subscriptions auto-renew until cancelled in Settings > Apple ID > Subscriptions at least 24 hours before the end of the current period. Payment is charged to your Apple ID. Any unused portion of a free trial is forfeited when you subscribe." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Subscriptions auto-renew until cancelled in Settings > Apple ID > Subscriptions at least 24 hours before the end of the current period. Payment is charged to your Apple ID. Any unused portion of a free trial is forfeited when you subscribe." } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "Las suscripciones se renuevan automáticamente hasta que las canceles en Ajustes > ID de Apple > Suscripciones al menos 24 horas antes del final del periodo actual. El cargo se realiza a tu ID de Apple. Si tienes un periodo de prueba gratuito en curso, la parte no utilizada se pierde al suscribirte." } }
      }
    },
